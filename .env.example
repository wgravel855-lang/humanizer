# Required — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# Required for payments — get from https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# Required — random string, used to sign Pro tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=change-me-to-a-long-random-string

# Optional — your production URL (e.g. https://humanize.ai). Falls back to request origin.
NEXT_PUBLIC_APP_URL=

# Optional — Upstash Redis for production rate limiting + subscription state
# Create a free Redis DB at https://upstash.com (10k commands/day free)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — override defaults
# FREE_DAILY_LIMIT=5
# FREE_CHAR_LIMIT=500

